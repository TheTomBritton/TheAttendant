# ProcessWire core (managed by Composer)
/wire/
/index.php
/.htaccess
/install.php

# Composer
/vendor/
composer.lock

# Node
node_modules/
package-lock.json

# Build output (regenerated by npm/vite build)
/site/assets/dist/
sites/*/assets/dist/

# ProcessWire runtime files
/site/assets/cache/
/site/assets/files/
/site/assets/logs/
/site/assets/sessions/
/site/assets/backups/
/site/assets/active.php
/site/assets/installed.php
/site/assets/.htaccess
/site/.htaccess
/captchaimage.php

# PW installer files (kept in sites/<project>/install/ instead)
/site/install/install.sql
/site/install/info.php
/site/install/files/

# PW modules (cloned per-environment, not committed)
/site/modules/

# Environment files
/docker/.env

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE / Editor
.idea/
.vscode/
*.swp
*.swo
*~

# Temporary files
*.tmp
*.bak

# Playwright MCP artefacts
.playwright-mcp/
