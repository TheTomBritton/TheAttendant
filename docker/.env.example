# Project name — used for Docker container naming
PROJECT_NAME=pw-project
COMPOSE_PROJECT_NAME=pw-project

# Web server port (change if 8080 is in use)
WEB_PORT=8080

# Adminer (database admin UI) port
ADMINER_PORT=8081

# Database credentials
DB_NAME=pw_dev
DB_USER=pw_user
DB_PASS=pw_password
DB_ROOT_PASS=root_password
DB_PORT=3306

# ProcessWire admin (reference only — used during PW web installer)
PW_ADMIN_USER=admin
PW_ADMIN_PASS=change-this-password
