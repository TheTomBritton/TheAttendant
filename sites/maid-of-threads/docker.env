# Maid of Threads — Docker environment
PROJECT_NAME=maid-of-threads
COMPOSE_PROJECT_NAME=maid-of-threads

# Web server port (change if 8080 is in use)
WEB_PORT=8080

# Adminer (database admin UI) port
ADMINER_PORT=8081

# Database credentials
DB_NAME=mot_dev
DB_USER=mot_user
DB_PASS=mot_password
DB_ROOT_PASS=root_password
DB_PORT=3306

# ProcessWire admin (reference only — used during PW web installer)
PW_ADMIN_USER=admin
PW_ADMIN_PASS=change-this-password
